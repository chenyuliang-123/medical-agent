# ==================== LLM 配置 ====================
# LLM提供商选择: openai 或 zhipu（推荐国内用户使用智谱AI）
LLM_PROVIDER=zhipu
LLM_TEMPERATURE=0.7

# ==================== OpenAI 配置 ====================
# 如果使用 OpenAI，请配置以下内容
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

# ==================== 智谱AI 配置（推荐）====================
# 注册地址: https://open.bigmodel.cn/
# 新用户免费赠送 2500万 Token
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4
# 可选模型: glm-4, glm-4-plus, glm-4-flash

# ==================== 应用配置 ====================
APP_ENV=production
LOG_LEVEL=info

# ==================== CORS 配置 ====================
# 多个域名用逗号分隔
CORS_ORIGINS=http://localhost,http://localhost:80

# ==================== 数据库配置 ====================
# 使用外部 MySQL 服务器（推荐）
# 格式: mysql+pymysql://用户名:密码@主机:端口/数据库名?charset=utf8mb4
DATABASE_URL=mysql+pymysql://root:mysql112@10.10.31.112:3306/ai_slow?charset=utf8mb4

# 可选：如果使用 SQLite
# DATABASE_URL=sqlite:///./data/agent.db

# 可选：如果使用 PostgreSQL
# DATABASE_URL=postgresql://user:password@postgres:5432/agent_db

# ==================== 向量数据库配置 ====================
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# ==================== Agent 配置 ====================
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=True
